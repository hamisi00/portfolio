// Firestore Security Rules for Portfolio Website
// These rules should be deployed to your Firebase project
// Deploy using: firebase deploy --only firestore:rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Beyond the Classroom Collection
    match /beyondClassroom/{activityId} {
      // Allow anyone to read published activities
      allow read: if resource.data.published == true;

      // Allow authenticated users to read all activities (for admin panel)
      allow read: if request.auth != null;

      // Allow only authenticated users to create, update, and delete
      allow create, update, delete: if request.auth != null;
    }

    // Deny all other collections by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
